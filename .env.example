# =============================================================================
# Supabase — LMS Apoteker Rahmato
# =============================================================================
# Frontend (VITE_*) — dibundel ke browser, hanya anon key (aman untuk publik):
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only (BFF /api) — JANGAN prefix VITE_ (service role bypass RLS):
SUPABASE_URL=your-project-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# SSO Ventera (OIDC) — dipakai server /api/auth/* & vite middleware
# =============================================================================
SSO_ISSUER=https://sso.ventera.ai
SSO_CLIENT_ID=lms-apoteker-rahmato
SSO_CLIENT_SECRET=your-client-secret
APP_BASE_URL=https://rahmato.storo.id       # base URL app (redirect_uri callback)
SESSION_SECRET=ganti-min-32-karakter-acak   # kunci enkripsi cookie sesi (JWE)

# =============================================================================
# Bootstrap PERAN (student/mentor/admin) — sumber kebenaran = tabel user_roles.
# Env di bawah HANYA bootstrap agar tidak "ayam-telur" saat tabel masih kosong.
# Comma-separated. ADMIN_EMAILS menang mutlak; MENTOR_EMAILS fallback bila DB
# belum punya baris. Setelah ada admin, kelola sisanya lewat panel /admin.
# =============================================================================
ADMIN_EMAILS=admin.ventera@contoh.com          # tim Ventera (operator platform)
MENTOR_EMAILS=rahmato.farmasi@gmail.com        # Apoteker Rahmato (dosen)

# =============================================================================
# Xendit Payment Gateway — gated via Internal Ventera
# =============================================================================
# Pembayaran Xendit di project ini TIDAK langsung ke Xendit. Callback Xendit
# masuk ke gateway terpusat milik Internal Ventera, lalu diteruskan ke edge
# function `lmsrhmt-payment-confirm` di sini. Project prefix: LMSRHMT.
#
# Variabel di bawah adalah SECRET EDGE FUNCTION (bukan var frontend `VITE_*`).
# JANGAN taruh di .env frontend — set lewat Supabase secrets:
#   supabase secrets set XENDIT_ENV="sandbox"
#   supabase secrets set XENDIT_API_KEY_SANDBOX="xnd_development_xxx"
#   supabase secrets set XENDIT_API_KEY_PRODUCTION="xnd_production_xxx"
#   supabase secrets set INTERNAL_TOKEN_SANDBOX="lmsrhmt_xxx"
#   supabase secrets set INTERNAL_TOKEN_PRODUCTION="lmsrhmt_xxx"
#   supabase secrets set APP_BASE_URL="https://your-lms-domain"
#
# XENDIT_ENV                 -> "sandbox" (default aman) atau "production"
# XENDIT_API_KEY_SANDBOX     -> Xendit Sandbox → Settings → API Keys (Secret Key)
# XENDIT_API_KEY_PRODUCTION  -> Xendit Production → Settings → API Keys (Secret Key)
# INTERNAL_TOKEN_SANDBOX     -> token yang dipakai gateway saat forward callback (sandbox)
# INTERNAL_TOKEN_PRODUCTION  -> token yang dipakai gateway saat forward callback (production)
#                               HARUS sama persis dengan yang didaftarkan di
#                               xendit_routing_table Internal Ventera (prefix LMSRHMT).
# APP_BASE_URL               -> base URL app untuk redirect success/failed Xendit
